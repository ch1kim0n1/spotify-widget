{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spotify Companion Widget",
  "version": "0.1.0",
  "identifier": "com.vladislav.spotify-companion-widget",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Spotify Companion Widget",
        "width": 420,
        "height": 172,
        "minWidth": 360,
        "minHeight": 144,
        "maxWidth": 420,
        "maxHeight": 172,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "center": true
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": "default-src 'self'; img-src 'self' asset: data: https://i.scdn.co https://mosaic.scdn.co; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg"],
    "category": "Music",
    "shortDescription": "Control and inspect an existing Spotify playback session.",
    "longDescription": "A compact tray and menu-bar companion that controls and displays an existing Spotify playback session.",
    "copyright": "Copyright © 2026 Vladislav Kondratyev",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": null,
      "entitlements": "Entitlements.plist"
    }
  }
}
